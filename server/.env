# MongoDB Connection URI
# Replace the string below with your MongoDB Atlas cluster URI
# E.g. mongodb+srv://<username>:<password>@cluster0.abcde.mongodb.net/tutorfinder?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/ManageUser

# Port for the Node/Express server
PORT=5000

# Secret key for signing JSON Web Tokens (JWT)
JWT_SECRET=super_secret_jwt_key_for_development